# Copy to .env and replace every placeholder before using PostgreSQL Docker profiles.
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
DB_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
NEO4J_PASSWORD=replace-with-a-long-random-neo4j-password
ALLOWED_ORIGINS=http://127.0.0.1:8080
TRUSTED_PROXIES=
